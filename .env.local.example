# Supabase — Settings > API in your project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — only needed for the Admin panel (lock tournament, record wins).
# Keep this secret — never expose it on the client side.
# Settings > API > service_role (secret) key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The email address that gets access to the Admin panel
NEXT_PUBLIC_ADMIN_EMAIL=you@youremail.com
